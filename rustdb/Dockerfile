# Build stage
FROM rust:latest as builder

WORKDIR /app

COPY . .

RUN cargo build --release

# Runtime stage
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/target/release/rustdb-server /usr/local/bin/

EXPOSE 5432 9090

CMD ["rustdb-server"]
