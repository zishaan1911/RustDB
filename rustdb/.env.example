# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/rustdb
DATABASE_PATH=/data/rustdb

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=5432
SERVER_WORKERS=4

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Security
JWT_SECRET=your-secret-key-here
TLS_CERT_PATH=/etc/rustdb/certs/server.crt
TLS_KEY_PATH=/etc/rustdb/certs/server.key

# ML Configuration
MODEL_CACHE_SIZE=100
MODEL_CACHE_DIR=/data/models

# Observability
METRICS_ENABLED=true
TRACING_ENABLED=true
PROMETHEUS_PORT=9090

# Development
DEBUG=false
